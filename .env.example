# ============================================
# Correctover MCP Server - Environment Variables
# ============================================
# Copy this file to .env and fill in your keys.
# Only configure the providers you want to use.
# Keys never leave your machine (BYOK).
# ============================================

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-key
# OPENAI_BASE_URL=https://your-proxy.example.com/v1  # Uncomment for proxy/mirror

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# ANTHROPIC_BASE_URL=https://your-proxy.example.com/v1

# --- DeepSeek ---
DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_BASE_URL=https://your-proxy.example.com/v1

# --- Moonshot ---
MOONSHOT_API_KEY=sk-your-moonshot-key
# MOONSHOT_BASE_URL=https://your-proxy.example.com/v1

# --- Zhipu AI (GLM) ---
ZHIPU_API_KEY=your-zhipu-key
# ZHIPU_BASE_URL=https://your-proxy.example.com/v4

# --- Alibaba Qwen (DashScope) ---
DASHSCOPE_API_KEY=sk-your-dashscope-key
# DASHSCOPE_BASE_URL=https://your-proxy.example.com/v1

# --- SiliconFlow ---
SILICONFLOW_API_KEY=sk-your-siliconflow-key
# SILICONFLOW_BASE_URL=https://your-proxy.example.com/v1

# --- Groq ---
GROQ_API_KEY=gsk_your-groq-key
# GROQ_BASE_URL=https://your-proxy.example.com/v1

# --- Together AI ---
TOGETHER_API_KEY=your-together-key
# TOGETHER_BASE_URL=https://your-proxy.example.com/v1
